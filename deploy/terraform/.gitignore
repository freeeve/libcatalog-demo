# Terraform working files -- never commit the provider cache or state.
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
!*.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
# .terraform.lock.hcl IS committed (pins provider versions/hashes).

# Saved plan files (may contain resolved variable values)
tfplan
*.tfplan
